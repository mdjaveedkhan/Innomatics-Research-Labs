    "# Preprocessing Functions\n",
    "\n",
    "sample_text = \"I loooove this movie!!! 😍\"\n",
    "\n",
    "def preprocess_text(text):\n",
    "    \n",
    "    text = text.lower()\n",
    "    \n",
    "    # remove emojis & special characters\n",
    "    text = re.sub(r\"[^a-z\\s]\", \"\", text)\n",
    "    \n",
    "    # fix repeated characters (loooove → loove → love)\n",
    "    text = re.sub(r\"(.)\\1{2,}\", r\"\\1\\1\", text)  # step 1\n",
    "    text = re.sub(r\"(.)\\1+\", r\"\\1\", text)       # step 2\n",
    "    \n",
    "    words = text.split()\n",
    "    \n",
    "    # remove simple stopwords\n",
    "    stop_words = [\"i\", \"this\", \"is\", \"the\"]\n",
    "    \n",
    "    cleaned = []\n",
    "    for word in words:\n",
    "        if word not in stop_words:\n",
    "            cleaned.append(word)\n",
    "    \n",
    "    return \" \".join(cleaned)\n",
    "\n",
    "cleaned_text = preprocess_text(sample_text)\n",
    "\n",
    "print(\"Original Text:\", sample_text)\n",
    "print(\"Cleaned Text:\", cleaned_text)"
   ]
